# Copy this file to .env and fill in your values.
# Never commit .env to git.

# VirusTotal API key (optional — VT checks are skipped if blank)
VT_API_KEY=

# Redis connection string (optional — app runs without cache if blank)
REDIS_URL=redis://127.0.0.1:6379

# SQLAlchemy database URL
# SQLite for local dev:
DATABASE_URL=sqlite:///./threat_log.db
# PostgreSQL for production (uncomment and fill in):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# API key to protect /check and /logs endpoints (optional — leave blank to disable auth)
API_KEY=

# Runtime profile: development, testing, or production
ENVIRONMENT=development

# Trusted domain JSON file. Supports dynamic reload through UrlSecurityService.
TRUSTED_DOMAINS_PATH=trusted_domains.json

# Cache and HTTP tuning
CACHE_TTL_SECONDS=3600
TRUSTED_CACHE_TTL_SECONDS=21600
HTTP_TIMEOUT_SECONDS=5

# SSL verification is enabled by default for the modular pipeline.
VERIFY_SSL=true
ALLOW_INSECURE_SSL=false

# Comma-separated detector names can be supplied by deployment tooling if desired.
# ENABLED_DETECTORS=ml,heuristic,reputation,html,dns,ssl,whois,favicon,ocr
